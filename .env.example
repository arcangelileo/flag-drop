# ============================================================================
# FlagDrop — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
# All variables use the FLAGDROP_ prefix.
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — You must set this before running
# ---------------------------------------------------------------------------

# Secret key for signing JWT tokens. Use a long random string.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
FLAGDROP_SECRET_KEY=change-me-generate-a-real-secret-key

# ---------------------------------------------------------------------------
# OPTIONAL — Sensible defaults are provided
# ---------------------------------------------------------------------------

# Database connection string (async SQLAlchemy URL)
# SQLite (default):
FLAGDROP_DATABASE_URL=sqlite+aiosqlite:///./flagdrop.db
# PostgreSQL (production):
# FLAGDROP_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flagdrop

# Server bind address
FLAGDROP_HOST=0.0.0.0

# Server port
FLAGDROP_PORT=8000

# Enable debug mode (verbose SQL logging, stack traces)
FLAGDROP_DEBUG=false

# JWT token expiry in minutes (default: 1440 = 24 hours)
# FLAGDROP_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# JWT signing algorithm (default: HS256)
# FLAGDROP_JWT_ALGORITHM=HS256
